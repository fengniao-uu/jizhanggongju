# ============================================================
#  智能记账 / 房东收租管理系统 —— .env 配置模板
#  使用方式：复制本文件为 .env，修改其中值即可；切勿提交 .env 到公开仓库
# ============================================================

# ---------- JWT 密钥（必填，建议 64 字符以上高熵随机字符串） ----------
# 首次启动时若为空或弱占位符，系统会自动用 CSPRNG 生成 64 字符密钥并写入 .env
JWT_SECRET=please_change_me_to_a_long_random_string_at_least_64_chars

# ---------- CORS 跨域白名单（必填，生产务必修改！） ----------
# 多个域名用英文逗号分隔；不要留 *
# 示例：https://app.example.com,http://127.0.0.1:5188
CORS_ORIGINS=http://127.0.0.1:5188,http://localhost:5188

# ---------- 生产安全开关（生产环境强烈建议全部设为 1） ----------
# 1=关闭 Demo 账号（123456/123456）的自动创建；生产必须 1
DISABLE_DEMO_USER=1
# 1=关闭默认管理员（100000）的自动创建；设为 1 后需通过 DB 脚本或命令行手动创建首个管理员
DISABLE_DEFAULT_ADMIN=0
# 1=管理员首次登录若仍用默认密码（123456），强制要求改密后才能使用
ENFORCE_CHANGE_DEFAULT_ADMIN_PWD=1

# ---------- 自定义默认管理员账号密码（首次部署生效；已存在管理员时忽略） ----------
ADMIN_ACCOUNT=100000
ADMIN_PASSWORD=please_change_admin_default_password

# ---------- 数据库配置（使用 PostgreSQL / Supabase 时必填） ----------
# SQLite (默认): 留空即可，自动使用 backend/data/app.db
# PostgreSQL / Supabase: 格式 postgresql://user:password@host:port/database
DATABASE_URL=

# ---------- Supabase REST API 配置（Cloudflare Pages 使用时必填） ----------
# 在 Supabase Dashboard -> Settings -> API 中获取
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-anon-key-here
